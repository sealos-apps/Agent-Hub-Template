              },
              {
                "name": "api_mode",
                "label": "API Mode",
                "type": "select",
                "required": false,
                "options": [
                  {
                    "label": "OpenAI Responses",
                    "value": "openai-responses"
                  },
                  {
                    "label": "OpenAI Completions",
                    "value": "openai-completions"
                  },
                  {
                    "label": "Anthropic Messages",
                    "value": "anthropic-messages"
                  }
