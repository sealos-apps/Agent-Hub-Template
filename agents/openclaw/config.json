                "name": "provider",
                "label": "Provider ID",
                "type": "text",
                "required": true,
                "placeholder": "openai"
              }
            ]
          }
        ]
      },
      {
        "resource": "gateway",
        "label": "Gateway",
        "description": "Manage OpenClaw native gateway.mode, gateway.bind, gateway.port, and gateway token. Token read actions never return plaintext.",
        "actions": [
          {
            "action": "set-local",
            "kind": "write",
            "label": "Set Local Gateway",
            "args": [
              {
                "name": "bind",
                "label": "Bind",
                "type": "select",
                "required": false,
                "default": "lan",
                "options": [
                  {
                    "label": "LAN",
                    "value": "lan"
                  },
                  {
                    "label": "Loopback",
                    "value": "loopback"
                  },
                  {
                    "label": "Auto",
                    "value": "auto"
                  },
                  {
                    "label": "Tailnet",
                    "value": "tailnet"
                  },
                  {
                    "label": "Custom",
                    "value": "custom"
                  }
                ],
                "placeholder": "lan"
              },
              {
                "name": "port",
                "label": "Port",
                "type": "number",
                "required": false,
                "default": 18789,
                "placeholder": "18789"
              }
            ]
          },
          {
            "action": "get-local",
            "kind": "read",
            "label": "Get Gateway",
            "args": []
          },
          {
            "action": "set-token",
            "kind": "write",
            "label": "Set Gateway Token",
            "args": [
              {
                "name": "token",
                "label": "Token",
                "type": "password",
                "required": true,
                "placeholder": "change-me-local-dev",
                "sensitive": true
              }
            ]
          },
          {
            "action": "get-token",
            "kind": "read",
            "label": "Get Gateway Token Status",
            "args": []
          },
          {
            "action": "delete-token",
            "kind": "delete",
            "label": "Delete Gateway Token",
            "args": []
          }
        ]
      },
      {
        "resource": "workspace",
        "label": "Workspace",
        "description": "Manage OpenClaw native agents.defaults.workspace directly.",
        "actions": [
          {
            "action": "set",
            "kind": "write",
            "label": "Set Workspace",
            "args": [
              {
                "name": "path",
                "label": "Path",
                "type": "text",
                "required": true,
                "placeholder": "/workspace"
              }
            ]
          },
          {
            "action": "get",
            "kind": "read",
            "label": "Get Workspace",
            "args": []
          }
        ]
      },
      {
        "resource": "env",
        "label": ".env",
        "description": "Manage OpenClaw native ~/.openclaw/.env directly. Read actions only return configured status, never secret plaintext.",
        "actions": [
          {
            "action": "set",
            "kind": "write",
            "label": "Set Env Var",
            "args": [
              {
                "name": "key",
                "label": "Key",
                "type": "text",
                "required": true,
                "placeholder": "OPENAI_API_KEY"
              },
              {
                "name": "value",
                "label": "Value",
                "type": "password",
                "required": false,
                "placeholder": "sk-...",
                "sensitive": true
              }
            ]
          },
          {
            "action": "get",
            "kind": "read",
            "label": "Get Env Var Status",
            "args": [
              {
                "name": "key",
                "label": "Key",
                "type": "text",
                "required": true,
                "placeholder": "OPENAI_API_KEY"
              }
            ]
          },
          {
            "action": "delete",
            "kind": "delete",
            "label": "Delete Env Var",
            "args": [
              {
                "name": "key",
                "label": "Key",
                "type": "text",
                "required": true,
                "placeholder": "OPENAI_API_KEY"
              }
            ]
          },
          {
            "action": "list",
            "kind": "read",
            "label": "List .env Status",
            "args": []
          }
        ]
      }
    ]
  }
}
