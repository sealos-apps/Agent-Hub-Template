                "placeholder": "openai / anthropic / openrouter"
              },
              {
                "name": "model",
                "label": "Model",
                "type": "text",
                "required": true,
                "placeholder": "gpt-5.4"
              }
            ]
          },
          {
            "action": "get-main",
            "kind": "read",
            "label": "Get Main Model",
            "args": []
          }
        ]
      },
      {
        "resource": "provider",
        "label": "Provider Override",
        "description": "Manage OpenClaw native models.providers.<id> endpoint/api settings and models.providers.<id>.apiKey directly.",
        "actions": [
          {
            "action": "set",
