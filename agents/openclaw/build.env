AGENT_NAME=openclaw
AGENT_RUNTIME_KIND=service
NODE_MAJOR=22
# Latest stable npm-published OpenClaw release verified on 2026-05-18.
OPENCLAW_VERSION=2026.5.12
OPENCLAW_UPSTREAM_REF=e973aa278f18967789a3896fa2826607f7805cb6
OPENCLAW_STATE_DIR=/home/agent/.openclaw
OPENCLAW_CONFIG_PATH=/home/agent/.openclaw/openclaw.json
OPENCLAW_WORKSPACE=/workspace
OPENCLAW_PLUGIN_STAGE_DIR=/opt/openclaw/plugin-runtime-deps
