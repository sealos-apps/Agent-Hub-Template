AGENT_NAME=openclaw
AGENT_RUNTIME_KIND=service
NODE_MAJOR=22
# Latest npm-published OpenClaw release verified on 2026-04-26.
# reference/openclaw HEAD is 3b5463591be93c676a074134c5e384f8024a6945 and
# reports package.json version 2026.4.26, but that version is not published to npm yet.
OPENCLAW_VERSION=2026.4.24
OPENCLAW_UPSTREAM_REF=3b5463591be93c676a074134c5e384f8024a6945
OPENCLAW_STATE_DIR=/home/agent/.openclaw
OPENCLAW_CONFIG_PATH=/home/agent/.openclaw/openclaw.json
OPENCLAW_WORKSPACE=/workspace
OPENCLAW_PLUGIN_STAGE_DIR=/opt/openclaw/plugin-runtime-deps
