{
  "schemaVersion": "devbox-agent-config.v1",
  "script": "/opt/agent/config.sh",
  "zh": {
    "resources": [
      {
        "resource": "replace-me-resource",
        "label": "替换为该 Agent 的原生资源名",
        "description": "这里故意只放占位资源，维护者必须按 agent 原生配置方式重写。",
        "actions": [
          {
            "action": "replace-me-action",
            "kind": "write",
            "label": "替换为原生写入动作",
            "args": [
              {
                "name": "replace_me_arg",
                "label": "替换为原生参数名",
                "type": "text",
                "required": true,
                "placeholder": "replace-me"
              }
            ]
          },
          {
            "action": "replace-me-read",
            "kind": "read",
            "label": "替换为原生读取动作",
            "args": []
          }
        ]
      }
    ]
  },
  "en": {
    "resources": [
      {
        "resource": "replace-me-resource",
        "label": "Replace With Native Resource Name",
        "description": "This is intentionally a placeholder. Replace it with the target agent's native config resources and actions.",
        "actions": [
          {
            "action": "replace-me-action",
            "kind": "write",
            "label": "Replace With Native Write Action",
            "args": [
              {
                "name": "replace_me_arg",
                "label": "Replace With Native Argument",
                "type": "text",
                "required": true,
                "placeholder": "replace-me"
              }
            ]
          },
          {
            "action": "replace-me-read",
            "kind": "read",
            "label": "Replace With Native Read Action",
            "args": []
          }
        ]
      }
    ]
  }
}
