apiVersion: devbox.sealos.io/v1alpha2
kind: Devbox
metadata:
  name: {{ quote .Agent.Name }}
  namespace: {{ quote .Agent.Namespace }}
  labels:
{{- range $key, $value := .DevboxLabels }}
    {{ $key }}: {{ quote $value }}
{{- end }}
  annotations:
{{- range $key, $value := .DevboxAnnotations }}
    {{ $key }}: {{ quote $value }}
{{- end }}
spec:
  image: {{ quote .Image }}
  state: "Running"
  runtimeClassName: "devbox-runtime"
  storageLimit: {{ quote .Agent.Storage }}
  network:
    type: "SSHGate"
    extraPorts:
      - containerPort: 9899
  resource:
    cpu: {{ quote .Agent.CPU }}
    memory: {{ quote .Agent.Memory }}
  config:
    labels:
{{- range $key, $value := .SelectorLabels }}
      {{ $key }}: {{ quote $value }}
{{- end }}
    user: {{ quote .Agent.User }}
    workingDir: {{ quote .Agent.WorkingDir }}
    appPorts:
      - name: {{ quote .Agent.Name }}
        port: 9899
        protocol: "TCP"
        targetPort: 9899
    env:
      - name: "AGENT_NAME"
        value: "cowagent"
      - name: "AGENT_WORKSPACE"
        value: {{ quote .Agent.WorkingDir }}
      - name: "AGENT_DATA_DIR"
        value: "/root/.cowagent"
      - name: "AGENT_PORT"
        value: "9899"
      - name: "COWAGENT_HOME"
        value: "/root/.cowagent"
      - name: "COWAGENT_CHANNEL_TYPE"
        value: "web"
      - name: "COWAGENT_AGENT_WORKSPACE"
        value: {{ quote .Agent.WorkingDir }}
      - name: "OPEN_AI_API_KEY"
        value: {{ quote .Agent.ModelAPIKey }}
      - name: "OPEN_AI_API_BASE"
        value: {{ quote .Agent.ModelBaseURL }}
      - name: "OPENAI_API_KEY"
        value: {{ quote .Agent.ModelAPIKey }}
      - name: "OPENAI_BASE_URL"
        value: {{ quote .Agent.ModelBaseURL }}
      - name: "AGENT_MODEL_PROVIDER"
        value: {{ quote .Agent.ModelProvider }}
      - name: "AGENT_MODEL_BASEURL"
        value: {{ quote .Agent.ModelBaseURL }}
      - name: "AGENT_MODEL_APIKEY"
        value: {{ quote .Agent.ModelAPIKey }}
      - name: "AGENT_MODEL"
        value: {{ quote .Agent.Model }}
      - name: "AGENT_MODEL_API_MODE"
        value: {{ quote .Agent.ModelAPIMode }}
      - name: "AGENT_TEMPLATE_ID"
        value: {{ quote .Agent.TemplateID }}
      - name: "AGENT_WORKDIR"
        value: {{ quote .Agent.WorkingDir }}
    args:
      - start
