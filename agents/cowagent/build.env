AGENT_NAME=cowagent
AGENT_HOME=/opt/agent
COWAGENT_GIT_URL=https://github.com/zhayujie/CowAgent.git
COWAGENT_REF=master
COWAGENT_SRC=/opt/cowagent/src
COWAGENT_VENV=/opt/cowagent/venv
